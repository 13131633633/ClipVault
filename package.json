{
  "name": "clipvault",
  "private": true,
  "version": "1.0.0",
  "description": "ClipVault LAN clipboard sync for Windows, Linux, Android, and iOS.",
  "author": "OpenAI Codex",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "dev:electron": "wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron ./electron/main.mjs",
    "dev:desktop": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "build": "tsc -b && vite build",
    "build:desktop": "npm run build && electron-builder",
    "sync:native": "npm run build && npx cap sync",
    "open:android": "npx cap open android",
    "open:ios": "npx cap open ios",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "io.clipvault.desktop",
    "productName": "ClipVault",
    "directories": {
      "output": "release"
    },
    "files": [
      "assets/**/*",
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "icon": "assets/desktop-icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "installerIcon": "assets/desktop-icon.ico",
      "uninstallerIcon": "assets/desktop-icon.ico"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    }
  },
  "dependencies": {
    "@capacitor-mlkit/barcode-scanning": "^8.1.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "dayjs": "^1.11.21",
    "dexie": "^4.4.3",
    "dexie-react-hooks": "^4.4.0",
    "lucide-react": "^1.18.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  }
}
